# ============================================================
#  running-ball-db  —  environment configuration template
#  Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# PostgreSQL / Amazon RDS connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DB_URL=postgresql://sports_user:changeme@your-rds-instance.rds.amazonaws.com:5432/sports_db

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Ingestion settings
DB_BATCH_SIZE=500        # rows per executemany batch
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
